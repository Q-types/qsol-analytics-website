---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with QSol Analytics. Book a free discovery call or send us a message about your data science and automation needs."
>
  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Left Column: Info -->
        <div>
          <h1 class="text-4xl font-bold text-slate">Let's Talk</h1>
          <p class="mt-6 text-xl text-slate-light">
            Ready to put your data to work? Book a free 30-minute discovery call, or send us a message.
          </p>

          <div class="mt-12 space-y-8">
            <div>
              <h2 class="font-semibold text-slate">What to Expect</h2>
              <ul class="mt-4 space-y-3 text-slate-light">
                <li class="flex gap-3">
                  <svg class="w-5 h-5 text-brand-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  We'll discuss your current setup and challenges
                </li>
                <li class="flex gap-3">
                  <svg class="w-5 h-5 text-brand-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  You'll get honest feedback on whether we can help
                </li>
                <li class="flex gap-3">
                  <svg class="w-5 h-5 text-brand-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  No jargon, no hard sell—just a practical conversation
                </li>
              </ul>
            </div>

            <div>
              <h2 class="font-semibold text-slate">Direct Contact</h2>
              <p class="mt-4 text-slate-light">
                <strong>Email:</strong>{' '}
                <a href="mailto:hello@qsol-analytics.com" class="text-brand-blue hover:underline">
                  hello@qsol-analytics.com
                </a>
              </p>
              <p class="mt-2 text-slate-light">
                We typically respond within one business day.
              </p>
            </div>

            <div>
              <h2 class="font-semibold text-slate">Prefer to book directly?</h2>
              <p class="mt-4 text-slate-light">
                Skip the form and book a 30-minute discovery call at a time that suits you.
              </p>
              <a
                href="#"
                class="mt-4 btn-secondary inline-block"
              >
                Book a Discovery Call
              </a>
              <p class="mt-2 text-sm text-slate-light">(Calendly link - configure after setup)</p>
            </div>
          </div>
        </div>

        <!-- Right Column: Form -->
        <div class="bg-gray-50 p-8 rounded-lg">
          <h2 class="text-2xl font-bold text-slate">Send a Message</h2>
          <p class="mt-2 text-slate-light">We'll get back to you within one business day.</p>
          <div class="mt-8">
            <ContactForm />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
