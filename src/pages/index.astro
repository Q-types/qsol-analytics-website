  <!-- Problem Cards Interaction Script -->
  <script>
    document.querySelectorAll('.problem-card').forEach(card => {
      card.addEventListener('click', () => {
        const content = card.querySelector('.problem-content');
        const arrow = card.querySelector('.problem-arrow');
        const isOpen = !content?.classList.contains('hidden');

        // Close all other cards
        document.querySelectorAll('.problem-card').forEach(otherCard => {
          if (otherCard !== card) {
            otherCard.querySelector('.problem-content')?.classList.add('hidden');
            otherCard.querySelector('.problem-arrow')?.classList.remove('rotate-180');
          }
        });

        // Toggle this card
        content?.classList.toggle('hidden');
        arrow?.classList.toggle('rotate-180');
      });
    });
  </script>
