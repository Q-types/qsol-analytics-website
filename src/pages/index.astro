---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  {
    title: 'Operational Data Systems',
    description: 'Eliminate manual reporting and gain real-time visibility. Automated pipelines that save hours each week.',
    href: '/services/automation-workflow/',
    icon: '⚙️',
    timeline: '2–4 weeks'
  },
  {
    title: 'Predictive Analytics & Forecasting',
    description: 'Plan ahead with confidence. Demand forecasting and anomaly detection that help you respond before problems escalate.',
    href: '/services/forecasting-anomaly-detection/',
    icon: '📈',
    timeline: '3–6 weeks'
  },
  {
    title: 'Machine Learning & Pattern Discovery',
    description: 'Uncover hidden patterns in customer behaviour. Clustering and recommendations that drive better commercial decisions.',
    href: '/services/customer-segmentation/',
    icon: '🔍',
    timeline: '4–8 weeks'
  },
  {
    title: 'AI & Generative Tools',
    description: 'Bring advanced AI within reach. Intelligent assistants and automation that work with your existing workflows.',
    href: '/services/analytics-dashboards/',
    icon: '🤖',
    timeline: '3–6 weeks'
  }
];

const processSteps = [
  { title: 'Discovery', duration: '30 min call', description: 'We map your current setup and identify quick wins. You leave with clarity, not a sales pitch.' },
  { title: 'Assessment', duration: '1-3 days', description: 'We review your data and systems. You receive a written assessment with prioritised opportunities.' },
  { title: 'Build', duration: '2-4 weeks', description: 'We deliver a working prototype you can test with real data. Value before the main investment.' },
  { title: 'Refine', duration: '1 week', description: 'We refine based on feedback and ensure everything works in your environment.' },
  { title: 'Deploy', duration: 'Ongoing', description: 'Full documentation and handover—or ongoing support. You choose.' }
];

const differentiators = [
  { title: 'Rapid Time-to-Value', description: 'From discovery call to working prototype in 2-4 weeks. No six-month scoping phases.' },
  { title: 'Signal Over Noise', description: 'Physics-trained rigour applied to business systems. We focus on clarity, modelling, and practical decisions—not unnecessary complexity. You get insight, not more dashboards.' },
  { title: 'Measurable Outcomes', description: 'Success metrics agreed upfront. You see the ROI before the final invoice.' },
  { title: 'Right-Sized Solutions', description: 'If a spreadsheet fix solves your problem, we\'ll say so. No overselling.' },
  { title: 'Founder Access', description: 'Work directly with the founder, not handed to junior staff.' }
];

const sectors = ['Logistics', 'Distribution', 'Manufacturing', 'Retail', 'Professional Services', 'Facilities'];

const dataScienceExamples = [
  {
    problem: 'Manual reporting is eating your team\'s time',
    solution: 'Automated data pipelines that pull, clean, and format reports—daily or on-demand.',
    outcome: 'Hours saved each week. Fewer errors. Faster decisions.',
    icon: '📊'
  },
  {
    problem: 'Demand fluctuates and you\'re always catching up',
    solution: 'Forecasting models that predict demand at SKU, category, or aggregate level—with confidence intervals.',
    outcome: 'Better inventory planning. Fewer stockouts. Less working capital tied up.',
    icon: '📈'
  },
  {
    problem: 'You treat all customers the same',
    solution: 'Clustering and segmentation that identifies meaningful groups based on behaviour, value, and patterns.',
    outcome: 'Targeted marketing. Prioritised sales effort. Higher conversion.',
    icon: '🎯'
  },
  {
    problem: 'Problems become visible only after they\'re expensive',
    solution: 'Anomaly detection that spots unusual patterns in real-time—before they escalate.',
    outcome: 'Earlier warnings. Faster response. Lower incident costs.',
    icon: '🔔'
  },
  {
    problem: 'Your team answers the same questions repeatedly',
    solution: 'AI assistants trained on your business data—for internal knowledge retrieval and decision support.',
    outcome: 'Faster onboarding. Consistent answers. Time freed for higher-value work.',
    icon: '🤖'
  }
];

const problemCards = [
  {
    id: 'reporting',
    title: 'Reporting takes too long',
    why: 'Data lives in multiple spreadsheets, systems don\'t talk to each other, and someone has to manually pull it all together every week or month.',
    solution: 'Automated reporting pipelines that pull, clean, and format data—delivering reports on-demand or on schedule.',
    outcome: 'Teams typically save 5–10 hours per week and eliminate copy-paste errors.'
  },
  {
    id: 'demand',
    title: 'Demand is hard to predict',
    why: 'Historical patterns are buried in spreadsheets. Seasonal effects, trends, and anomalies aren\'t surfaced in time to act.',
    solution: 'Forecasting models that analyse historical data and produce demand predictions with confidence intervals.',
    outcome: 'Better inventory planning, fewer stockouts, and reduced working capital tied up in overstock.'
  },
  {
    id: 'customers',
    title: 'Customer data exists but insight is weak',
    why: 'Customer information is stored but not analysed. Everyone gets treated the same way regardless of value or behaviour.',
    solution: 'Clustering and segmentation models that identify meaningful customer groups based on actual patterns.',
    outcome: 'Improved targeting, prioritised sales effort, and higher conversion from marketing spend.'
  },
  {
    id: 'problems',
    title: 'Problems appear too late',
    why: 'Issues only surface after they\'ve become expensive—failed deliveries, quality problems, or operational breakdowns.',
    solution: 'Anomaly detection systems that monitor for unusual patterns and alert your team early.',
    outcome: 'Earlier warnings, faster response, and lower incident costs.'
  },
  {
    id: 'manual',
    title: 'Teams repeat the same manual work',
    why: 'Processes that could be automated are still done by hand. Staff time is consumed by low-value repetitive tasks.',
    solution: 'Workflow automation that handles routine data processing, freeing your team for higher-value work.',
    outcome: 'Reduced manual workload and more consistent, reliable outputs.'
  }
];

const engagements = [
  {
    title: 'Data & Reporting Automation Sprint',
    description: 'Designed for businesses spending too much time on manual reporting, spreadsheet copying, and disconnected admin workflows.',
    bullets: [
      'Automate repetitive reporting processes',
      'Connect and structure operational data',
      'Reduce spreadsheet dependency',
      'Create a reliable dashboard or reporting workflow'
    ],
    investment: '£3k–£8k',
    timeline: '2–4 weeks',
    icon: '⚡',
    typicalResult: 'Save 5–10 hours per week on reporting'
  },
  {
    title: 'Forecasting & Decision Support Project',
    description: 'Built for teams that need better planning, earlier warning signals, and more confidence in operational decisions.',
    bullets: [
      'Demand / workload forecasting',
      'Anomaly detection',
      'Predictive models for operational risk',
      'Decision-support dashboards'
    ],
    investment: '£5k–£15k',
    timeline: '3–6 weeks',
    icon: '📊',
    typicalResult: 'Earlier warning of demand changes and operational risks'
  },
  {
    title: 'Customer Intelligence & Recommendation System',
    description: 'For businesses with customer or client data who want better segmentation, prioritisation, and smarter targeting.',
    bullets: [
      'Clustering and customer segmentation',
      'Recommendation systems',
      'Lead / opportunity prioritisation',
      'Pattern discovery in customer behaviour'
    ],
    investment: '£6k–£20k',
    timeline: '4–8 weeks',
    icon: '🎯',
    typicalResult: 'Clear customer segments and better sales prioritisation'
  }
];

const caseStudies = [
  {
    title: 'Automated Data Processing for Acoustic Consultancy',
    description: 'Python automation system that processes measurement data, performs calculations, and generates structured consultancy reports.',
    result: 'Reduced reporting time significantly and improved calculation consistency'
  },
  {
    title: 'Estimating and MIS System for Bespoke Manufacturing',
    description: 'Operational data system designed to automate quoting workflows and provide clearer management insight.',
    result: 'Cut quoting turnaround from hours to minutes'
  },
  {
    title: 'Customer Clustering and Recommendation Modelling',
    description: 'Machine learning models to identify customer patterns and prioritise opportunities using clustering and recommendation logic.',
    result: 'Improved targeting and sales prioritisation'
  },
  {
    title: 'AI Lesson Planner for Science Cover Teaching',
    description: 'Automation system that generates structured lesson plans using curriculum inputs, difficulty levels, and knowledge checks.',
    result: 'Reduced lesson planning effort and improved consistency'
  }
];
---

<BaseLayout
  title="Data Science & Automation for Growing UK SMEs"
  description="QSol Analytics builds practical data systems — automation, dashboards, forecasting, machine learning and AI tools — designed for real operational businesses. Measurable results in weeks."
>
  <!-- Sticky CTA -->
  <div class="fixed bottom-6 right-6 z-40 hidden md:block">
    <a
      href="https://cal.com/q-types/30-minute-discovery-call"
      class="flex items-center gap-2 bg-brand-blue text-white px-4 py-3 rounded-full shadow-lg hover:bg-blue-700 transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <span class="font-medium">Book a Call</span>
    </a>
  </div>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-brand-blue-pale to-white py-16 lg:py-24">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-3xl lg:text-4xl xl:text-5xl font-bold text-slate leading-tight">
            Turn Operational Data into <span class="text-brand-blue">Better Decisions.</span>
          </h1>
          <p class="mt-3 text-lg lg:text-xl text-slate-light leading-relaxed">
            Forecast demand, detect problems early, and automate the reporting that slows your team down.
          </p>
          <p class="mt-4 text-base text-slate-light leading-relaxed">
            Practical data systems for UK SMEs — from automation and dashboards to forecasting and machine learning — built in weeks, not months.
          </p>
          <div class="mt-4 flex flex-col sm:flex-row gap-3 text-sm text-gray-500">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Typical prototype delivered in 2–4 weeks
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Best suited for 10–500 employees
            </span>
          </div>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a href="https://cal.com/q-types/30-minute-discovery-call" class="btn-primary text-lg px-8 py-4">
              Book a 30-Minute Discovery Call
            </a>
            <a href="/data-strategy/" class="btn-secondary text-lg px-8 py-4">
              See How It Works
            </a>
          </div>
          <p class="mt-3 text-sm text-gray-400">
            No preparation needed • No obligation
          </p>
        </div>

        <!-- Hero Visual: Data Transformation Diagram -->
        <div class="hidden lg:block">
          <img
            src="/images/hero-diagram.png"
            alt="Data transformation flow: Spreadsheets to Automation to Dashboard to Forecast"
            class="w-full max-w-lg mx-auto"
            width="600"
            height="400"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="py-16 lg:py-20">
    <div class="container-narrow">
      <h2 class="text-3xl font-bold text-slate">
        Your Data Should Work for You — Not the Other Way Around
      </h2>
      <div class="mt-8 space-y-4 text-slate-light">
        <ul class="list-disc pl-6 space-y-2">
          <li>Spreadsheets multiply faster than you can manage</li>
          <li>"Quick reports" take hours to assemble</li>
          <li>Problems appear only after they become expensive</li>
          <li>Teams spend more time gathering data than acting on it</li>
        </ul>
        <p class="pt-4">
          Growing businesses often reach a point where manual reporting, disconnected spreadsheets, and limited visibility start slowing everything down.
        </p>
        <p>
          Large consultancies often propose six-figure transformation projects. Off-the-shelf tools rarely fit how your business actually works.
        </p>
        <p class="pt-4">
          QSol Analytics builds practical data systems for operational SMEs, including:
        </p>
        <ul class="list-disc pl-6 space-y-2">
          <li>reporting and workflow automation</li>
          <li>operational dashboards and analytics</li>
          <li>forecasting and predictive modelling</li>
          <li>machine learning and AI tools tailored to real workflows</li>
        </ul>
        <p class="pt-4 font-medium text-slate">
          The goal is simple: help your team spend less time managing data and more time making decisions.
        </p>
      </div>
    </div>
  </section>

  <!-- Case Studies and Systems Built Section (Merged) -->
  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">Case Studies and Systems Built</h2>
      <p class="mt-4 text-center text-slate-light max-w-2xl mx-auto">
        Recent projects demonstrating how automation, analytics, and machine learning improve operational workflows.
      </p>
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {caseStudies.map((study) => (
          <a href="/case-studies/" class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-brand-blue transition-all group flex flex-col">
            <h3 class="font-semibold text-slate group-hover:text-brand-blue transition-colors">{study.title}</h3>
            <p class="mt-3 text-sm text-slate-light flex-grow">{study.description}</p>
            <div class="mt-4 pt-3 border-t border-gray-100">
              <p class="text-sm font-medium text-green-600">{study.result}</p>
            </div>
            <span class="mt-3 inline-flex items-center text-sm text-brand-blue font-medium">
              View case studies
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/case-studies/" class="btn-secondary">
          View All Case Studies
        </a>
      </div>
    </div>
  </section>

  <!-- What You'll Get From the Call Section -->
  <section class="py-16 lg:py-20">
    <div class="container-narrow">
      <h2 class="text-3xl font-bold text-slate text-center">What You'll Get From the Call</h2>
      <div class="mt-8 text-slate-light">
        <p>During a 30-minute call we will:</p>
        <ul class="mt-4 list-disc pl-6 space-y-2">
          <li>map how data currently flows through your business</li>
          <li>identify where automation or analytics could save time</li>
          <li>highlight 2–3 practical improvements you could implement quickly</li>
        </ul>
        <p class="mt-6">
          There is no preparation required and no obligation to proceed.
        </p>
        <p class="mt-4 text-slate font-medium">
          These conversations are most useful for operations-heavy SMEs with around 10–500 employees.
        </p>
      </div>
      <div class="mt-8 text-center">
        <a href="https://cal.com/q-types/30-minute-discovery-call" class="btn-primary">
          Book a 30-Minute Discovery Call
        </a>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">What We Do</h2>
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/services/" class="btn-secondary">
          View All Services
        </a>
      </div>
    </div>
  </section>

  <!-- What Data Science Can Actually Do Section (Card-based) -->
  <section class="py-16 lg:py-20">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">What Data Science Can Actually Do for Your Business</h2>
      <p class="mt-4 text-center text-slate-light max-w-2xl mx-auto">
        Not sure what's possible? Here are five common problems we solve—and what the results look like.
      </p>
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {dataScienceExamples.map((example) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow">
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0">{example.icon}</span>
              <div>
                <h3 class="font-semibold text-slate">{example.problem}</h3>
                <p class="mt-2 text-sm text-slate-light">{example.solution}</p>
                <p class="mt-3 text-sm font-medium text-green-600">{example.outcome}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <p class="text-slate-light mb-4">Not sure where to start?</p>
        <a href="/diagnostic/" class="btn-secondary">
          Take the Data Opportunity Diagnostic
        </a>
      </div>
    </div>
  </section>

  <!-- Self-Identification Loop Section -->
  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">Where Is Data Slowing Your Business Down?</h2>
      <p class="mt-4 text-center text-slate-light max-w-2xl mx-auto">
        Select the challenge that feels most familiar. We'll show what typically causes it and what kind of solution usually helps.
      </p>
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-4" id="problem-cards">
        {problemCards.map((card) => (
          <div class="problem-card bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-brand-blue transition-colors cursor-pointer" data-card-id={card.id}>
            <div class="p-5 flex items-center justify-between">
              <h3 class="font-semibold text-slate">{card.title}</h3>
              <svg class="w-5 h-5 text-gray-400 problem-arrow transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
            <div class="problem-content hidden border-t border-gray-100 p-5 bg-gray-50">
              <div class="space-y-4">
                <div>
                  <p class="text-xs font-semibold text-red-600 uppercase tracking-wide mb-1">Why this happens</p>
                  <p class="text-sm text-slate-light">{card.why}</p>
                </div>
                <div>
                  <p class="text-xs font-semibold text-brand-blue uppercase tracking-wide mb-1">What usually helps</p>
                  <p class="text-sm text-slate-light">{card.solution}</p>
                </div>
                <div>
                  <p class="text-xs font-semibold text-green-600 uppercase tracking-wide mb-1">Typical outcome</p>
                  <p class="text-sm text-slate-light">{card.outcome}</p>
                </div>
                <div class="pt-2">
                  <a href="https://cal.com/q-types/30-minute-discovery-call" class="inline-flex items-center text-sm font-medium text-brand-blue hover:underline">
                    Discuss This Challenge
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Typical Engagements Section -->
  <section class="py-16 lg:py-20">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">Typical Engagements</h2>
      <p class="mt-4 text-center text-slate-light max-w-2xl mx-auto">
        Clear, scoped projects with fixed pricing. Choose the engagement that fits your current challenge.
      </p>
      <div class="mt-12 grid md:grid-cols-3 gap-8">
        {engagements.map((engagement) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-3xl">{engagement.icon}</span>
              <h3 class="text-lg font-semibold text-slate">{engagement.title}</h3>
            </div>
            <p class="text-slate-light text-sm mb-4">{engagement.description}</p>
            <ul class="space-y-2 mb-4 flex-grow">
              {engagement.bullets.map((bullet) => (
                <li class="flex items-start gap-2 text-sm text-slate-light">
                  <svg class="w-4 h-4 text-brand-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
            <div class="bg-green-50 rounded-lg p-3 mb-4">
              <p class="text-xs font-semibold text-green-700 uppercase tracking-wide mb-1">Typical result</p>
              <p class="text-sm text-green-800">{engagement.typicalResult}</p>
            </div>
            <div class="border-t border-gray-100 pt-4 mt-auto">
              <div class="flex justify-between items-center text-sm">
                <div>
                  <span class="text-slate-light">Investment:</span>
                  <span class="font-semibold text-slate ml-1">{engagement.investment}</span>
                </div>
                <div>
                  <span class="text-slate-light">Timeline:</span>
                  <span class="font-semibold text-brand-blue ml-1">{engagement.timeline}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="how-it-works" class="py-16 lg:py-20 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">How It Works</h2>
      <p class="mt-4 text-center text-slate-light">A lightweight process designed for busy teams</p>
      <div class="mt-12 grid md:grid-cols-5 gap-6">
        {processSteps.map((step, index) => (
          <div class="text-center">
            <div class="w-12 h-12 bg-brand-blue text-white rounded-full flex items-center justify-center mx-auto font-bold text-lg">
              {index + 1}
            </div>
            <h3 class="mt-4 font-semibold text-slate">{step.title}</h3>
            <p class="text-sm text-brand-blue font-medium">{step.duration}</p>
            <p class="mt-2 text-sm text-slate-light">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial Section (Placeholder) -->
  <section class="py-16 lg:py-20">
    <div class="container-narrow">
      <div class="bg-brand-blue-pale rounded-2xl p-8 lg:p-12 text-center">
        <svg class="w-10 h-10 text-brand-blue mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
        </svg>
        <blockquote class="text-xl lg:text-2xl text-slate font-medium leading-relaxed">
          "Reduced our reporting workload and gave the team much better operational visibility."
        </blockquote>
        <div class="mt-6">
          <p class="font-semibold text-slate">Operations Manager</p>
          <p class="text-sm text-slate-light">Manufacturing Business</p>
        </div>
      </div>
      <p class="mt-6 text-center text-sm text-slate-light">
