---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';

const services = [
  {
    title: 'Operational Data Systems',
    description: 'Automation pipelines, live dashboards, and data integration that eliminate manual work and give your team real-time visibility.',
    href: '/services/automation-workflow/',
    icon: '⚙️',
    timeline: '2–4 weeks'
  },
  {
    title: 'Predictive Analytics & Forecasting',
    description: 'Demand forecasting, anomaly detection, and trend analysis that help you plan ahead and respond before problems escalate.',
    href: '/services/forecasting-anomaly-detection/',
    icon: '📈',
    timeline: '3–6 weeks'
  },
  {
    title: 'Machine Learning & Pattern Discovery',
    description: 'Customer clustering, recommendation systems, and ensemble models that uncover hidden patterns and drive better decisions.',
    href: '/services/customer-segmentation/',
    icon: '🔍',
    timeline: '4–8 weeks'
  },
  {
    title: 'AI & Generative Tools',
    description: 'Neural networks, intelligent assistants, and AI-powered automation that bring advanced capabilities within reach of growing businesses.',
    href: '/services/analytics-dashboards/',
    icon: '🤖',
    timeline: '3–6 weeks'
  }
];

const processSteps = [
  { title: 'Discovery', duration: '30 min call', description: 'We discuss your setup, pain points, and goals. No jargon, no hard sell.' },
  { title: 'Assessment', duration: '1-3 days', description: 'We review your data and systems. You receive a written assessment with quick wins and opportunities.' },
  { title: 'Build', duration: '2-4 weeks', description: 'We build a working solution you can test with real data. Results before the main investment.' },
  { title: 'Refine', duration: '1 week', description: 'We refine based on feedback and ensure everything works in your environment.' },
  { title: 'Deploy', duration: 'Ongoing', description: 'Full documentation and handover—or ongoing support. You choose.' }
];

const differentiators = [
  { title: 'Rapid Time-to-Value', description: 'From discovery call to working prototype in 2-4 weeks. No six-month scoping phases.' },
  { title: 'Signal Over Noise', description: 'Physics-trained rigour applied to business problems. You get clarity, not more dashboards.' },
  { title: 'Measurable Outcomes', description: 'Success metrics agreed upfront. You see the ROI before the final invoice.' },
  { title: 'Right-Sized Solutions', description: 'If a spreadsheet fix solves your problem, we\'ll say so. No overselling.' },
  { title: 'Founder Access', description: 'Work directly with the founder, not handed to junior staff.' }
];

const sectors = ['Logistics', 'Distribution', 'Manufacturing', 'Retail', 'Professional Services', 'Facilities'];

const dataScienceExamples = [
  {
    problem: 'Manual reporting is eating your team\'s time',
    solution: 'Automated data pipelines that pull, clean, and format reports—daily or on-demand.',
    outcome: 'Hours saved each week. Fewer errors. Faster decisions.',
    icon: '📊'
  },
  {
    problem: 'Demand fluctuates and you\'re always catching up',
    solution: 'Forecasting models that predict demand at SKU, category, or aggregate level—with confidence intervals.',
    outcome: 'Better inventory planning. Fewer stockouts. Less working capital tied up.',
    icon: '📈'
  },
  {
    problem: 'You treat all customers the same',
    solution: 'Clustering and segmentation that identifies meaningful groups based on behaviour, value, and patterns.',
    outcome: 'Targeted marketing. Prioritised sales effort. Higher conversion.',
    icon: '🎯'
  },
  {
    problem: 'Problems become visible only after they\'re expensive',
    solution: 'Anomaly detection that spots unusual patterns in real-time—before they escalate.',
    outcome: 'Earlier warnings. Faster response. Lower incident costs.',
    icon: '🔔'
  },
  {
    problem: 'Your team answers the same questions repeatedly',
    solution: 'AI assistants trained on your business data—for internal knowledge retrieval and decision support.',
    outcome: 'Faster onboarding. Consistent answers. Time freed for higher-value work.',
    icon: '🤖'
  }
];

const engagements = [
  {
    title: 'Data & Reporting Automation Sprint',
    description: 'Designed for businesses spending too much time on manual reporting, spreadsheet copying, and disconnected admin workflows.',
    bullets: [
      'Automate repetitive reporting processes',
      'Connect and structure operational data',
      'Reduce spreadsheet dependency',
      'Create a reliable dashboard or reporting workflow'
    ],
    investment: '£3k–£8k',
    timeline: '2–4 weeks',
    icon: '⚡'
  },
  {
    title: 'Forecasting & Decision Support Project',
    description: 'Built for teams that need better planning, earlier warning signals, and more confidence in operational decisions.',
    bullets: [
      'Demand / workload forecasting',
      'Anomaly detection',
      'Predictive models for operational risk',
      'Decision-support dashboards'
    ],
    investment: '£5k–£15k',
    timeline: '3–6 weeks',
    icon: '📊'
  },
  {
    title: 'Customer Intelligence & Recommendation System',
    description: 'For businesses with customer or client data who want better segmentation, prioritisation, and smarter targeting.',
    bullets: [
      'Clustering and customer segmentation',
      'Recommendation systems',
      'Lead / opportunity prioritisation',
      'Pattern discovery in customer behaviour'
    ],
    investment: '£6k–£20k',
    timeline: '4–8 weeks',
    icon: '🎯'
  }
];

const projects = [
  {
    title: 'AI Lesson Planner for Science Cover Teaching',
    category: 'Workflow Automation & Intelligent Content',
    problem: 'Teachers and cover staff often lose time preparing lessons at different difficulty levels and adapting content quickly.',
    solution: 'Developed a Python-based lesson planning system that integrates educational best practice, syllabus content, challenge tasks, and knowledge-check questions to generate structured lesson plans efficiently.',
    outcomes: [
      'Reduces lesson preparation time',
      'Improves consistency of lesson structure',
      'Supports differentiated delivery across ability levels'
    ]
  },
  {
    title: 'Estimating and MIS System for Bespoke Manufacturing',
    category: 'Operational Data Systems',
    problem: 'A bespoke packaging manufacturer relied on manual estimating processes and fragmented management information, making quoting and decision-making slow and inconsistent.',
    solution: 'Designed and scoped a smarter estimating / MIS system to centralise operational variables, automate parts of the quoting process, and support more reliable management insight.',
    outcomes: [
      'Reduces estimating friction',
      'Improves consistency in quoting',
      'Lays the foundation for stronger operational reporting and future forecasting'
    ]
  },
  {
    title: 'Customer Clustering and Recommendation Modelling',
    category: 'Machine Learning & Customer Intelligence',
    problem: 'Businesses often hold customer data but lack clear ways to identify meaningful groups, prioritise opportunities, or understand which customers are likely to respond to different products or services.',
    solution: 'Developed clustering and recommendation approaches to uncover behavioural patterns in customer data and support smarter targeting and prioritisation.',
    outcomes: [
      'Helps businesses understand customer segments',
      'Improves targeting and prioritisation',
      'Supports more informed commercial decision-making'
    ]
  },
  {
    title: 'Automated Data Processing for Acoustic Consultancy',
    category: 'Automation & Data Engineering',
    problem: 'Noise and acoustic consultancies collect large volumes of measurement data during investigations. Processing this data and producing formal reports requires repetitive manual steps—importing data, filtering signals, performing calculations, and formatting results—which is time-consuming and prone to error.',
    solution: 'Developed a Python-based automation system that imports and processes acoustic measurement datasets, performs required calculations and transformations, and generates formatted report sections referencing relevant regulatory standards.',
    outcomes: [
      'Reduced manual data processing effort',
      'Improved consistency of calculations and reporting',
      'Enabled faster turnaround of consultancy reports'
    ]
  }
];
---

<BaseLayout
  title="Data Science & Automation for Growing UK SMEs"
  description="QSol Analytics builds practical data systems — automation, dashboards, forecasting, machine learning and AI tools — designed for real operational businesses. Measurable results in weeks."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-brand-blue-pale to-white py-20 lg:py-28">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h1 class="text-4xl lg:text-5xl font-bold text-slate leading-tight">
          Data Science & Automation for Growing UK SMEs
        </h1>
        <p class="mt-6 text-xl text-slate-light leading-relaxed">
          We build practical data systems — from automation and dashboards to forecasting, machine learning and AI tools — designed for real operational businesses.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="https://cal.com/q-types/30-minute-discovery-call" class="btn-primary text-lg px-8 py-4">
            Book a 30-Minute Discovery Call
          </a>
          <a href="/data-strategy/" class="btn-secondary text-lg px-8 py-4">
            See How It Works
          </a>
        </div>
        <p class="mt-4 text-sm text-gray-500 text-center sm:text-left">
          30-minute conversation • No preparation needed • No obligation
        </p>
      </div>
    </div>
  </section>

  <!-- Problem/Solution Section -->
  <section class="py-16 lg:py-24">
    <div class="container-narrow">
      <h2 class="text-3xl font-bold text-slate">
        Your Data Should Work for You — Not the Other Way Around
      </h2>
      <div class="mt-8 space-y-4 text-slate-light">
        <p>If you're running operations, finance, or commercial functions in a growing SME, you may recognise some of these problems:</p>
        <ul class="list-disc pl-6 space-y-2">
          <li>Spreadsheets multiply faster than you can maintain them</li>
          <li>"Quick" reports take hours to pull together</li>
          <li>Problems become visible only after they've become expensive</li>
          <li>Your team spends more time gathering data than acting on it</li>
        </ul>
        <p class="pt-4">
          Most growing businesses reach a point where manual reporting, disconnected spreadsheets, and limited visibility start slowing everything down.
        </p>
        <p class="pt-2">
          Large consultancies often propose six-figure transformation projects. Off-the-shelf tools rarely match how your business actually works.
        </p>
        <p class="pt-4">
          QSol Analytics builds practical data systems for operational SMEs, including:
        </p>
        <ul class="list-disc pl-6 space-y-2">
          <li>reporting and workflow automation</li>
          <li>operational dashboards and analytics</li>
          <li>forecasting and predictive modelling</li>
          <li>machine learning and AI tools tailored to real workflows</li>
        </ul>
        <p class="pt-4 font-medium text-slate">
          The goal is simple: help your team spend less time managing data and more time making decisions.
        </p>
      </div>
    </div>
  </section>

  <!-- Recent Work and Systems Built Section -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">Recent Work and Systems Built</h2>
      <p class="mt-4 text-center text-slate-light max-w-2xl mx-auto">
        Recent projects demonstrate how automation, analytics, and machine learning can improve operational workflows across different industries.
      </p>
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/case-studies/" class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-slate group-hover:text-brand-blue transition-colors">Automated Data Processing for Acoustic Consultancy</h3>
          <p class="mt-3 text-sm text-slate-light">Python automation system that processes measurement data, performs calculations, and generates structured consultancy reports.</p>
          <span class="mt-4 inline-flex items-center text-sm text-brand-blue font-medium">
            View case studies
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
        <a href="/case-studies/" class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-slate group-hover:text-brand-blue transition-colors">Estimating and MIS System for Manufacturing</h3>
          <p class="mt-3 text-sm text-slate-light">Operational data system designed to automate quoting workflows and provide clearer management insight for a bespoke packaging manufacturer.</p>
          <span class="mt-4 inline-flex items-center text-sm text-brand-blue font-medium">
            View case studies
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
        <a href="/case-studies/" class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-slate group-hover:text-brand-blue transition-colors">Customer Clustering and Recommendation Models</h3>
          <p class="mt-3 text-sm text-slate-light">Machine learning models used to identify customer patterns and prioritise opportunities using clustering and recommendation logic.</p>
          <span class="mt-4 inline-flex items-center text-sm text-brand-blue font-medium">
            View case studies
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
        <a href="/case-studies/" class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-brand-blue transition-all group">
          <h3 class="font-semibold text-slate group-hover:text-brand-blue transition-colors">AI Lesson Planning System</h3>
          <p class="mt-3 text-sm text-slate-light">Automation system that generates structured science lesson plans using curriculum inputs, difficulty levels, and knowledge checks.</p>
          <span class="mt-4 inline-flex items-center text-sm text-brand-blue font-medium">
            View case studies
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>
      <div class="mt-10 text-center">
        <a href="/case-studies/" class="btn-secondary">
          View All Case Studies
        </a>
      </div>
    </div>
  </section>

  <!-- What Happens in a Discovery Call Section -->
  <section class="py-16 lg:py-24">
    <div class="container-narrow">
      <h2 class="text-3xl font-bold text-slate text-center">What Happens in a Discovery Call</h2>
      <div class="mt-8 text-slate-light">
        <p>During a 30-minute discovery call we will:</p>
        <ul class="mt-4 list-disc pl-6 space-y-2">
          <li>discuss how data currently flows through your business</li>
          <li>identify areas where automation, analytics, or forecasting could help</li>
          <li>explore practical next steps if improvements are possible</li>
        </ul>
        <p class="mt-6">
          There is no preparation required and no obligation to proceed with a project.
        </p>
        <p class="mt-4 text-slate font-medium">
          These conversations are most useful for operations-heavy SMEs with around 10–500 employees.
        </p>
      </div>
      <div class="mt-8 text-center">
        <a href="https://cal.com/q-types/30-minute-discovery-call" class="btn-primary">
          Book a 30-Minute Discovery Call
        </a>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">What We Do</h2>
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/services/" class="btn-secondary">
          View All Services
        </a>
      </div>
    </div>
  </section>

  <!-- What Data Science Can Actually Do Section -->
  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">What Data Science Can Actually Do for Your Business</h2>
      <p class="mt-4 text-center text-slate-light max-w-2xl mx-auto">
        Not sure what's possible? Here are five common problems we solve—and what the results look like.
      </p>
      <div class="mt-12 space-y-6">
        {dataScienceExamples.map((example) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow">
            <div class="grid md:grid-cols-12 gap-6 items-start">
              <div class="md:col-span-1 flex justify-center md:justify-start">
                <span class="text-3xl">{example.icon}</span>
              </div>
              <div class="md:col-span-3">
                <h3 class="text-sm font-semibold text-red-600 uppercase tracking-wide mb-1">Problem</h3>
                <p class="text-slate font-medium">{example.problem}</p>
              </div>
              <div class="md:col-span-4">
                <h3 class="text-sm font-semibold text-brand-blue uppercase tracking-wide mb-1">Solution</h3>
                <p class="text-slate-light">{example.solution}</p>
              </div>
              <div class="md:col-span-4">
                <h3 class="text-sm font-semibold text-green-600 uppercase tracking-wide mb-1">Outcome</h3>
                <p class="text-slate-light">{example.outcome}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <p class="text-slate-light mb-4">Not sure if your business is ready for data science?</p>
        <a href="/diagnostic/" class="btn-primary">
          Take the Data Opportunity Diagnostic
        </a>
      </div>
    </div>
  </section>

  <!-- Real Problems We Solve Section -->
  <section class="py-12 lg:py-16 border-y border-gray-200">
    <div class="container-wide">
      <h2 class="text-xl font-semibold text-slate text-center mb-8">Real Problems We Solve</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-brand-blue-pale rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <p class="text-sm text-slate-light">Forecasting demand before it hits</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-brand-blue-pale rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <p class="text-sm text-slate-light">Detecting anomalies before they escalate</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-brand-blue-pale rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <p class="text-sm text-slate-light">Automating reporting pipelines</p>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-12 h-12 bg-brand-blue-pale rounded-full flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <p class="text-sm text-slate-light">Prioritising high-value customers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Typical Engagements Section -->
  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">Typical Engagements</h2>
      <p class="mt-4 text-center text-slate-light max-w-2xl mx-auto">
        Clear, scoped projects with fixed pricing. Choose the engagement that fits your current challenge.
      </p>
      <div class="mt-12 grid md:grid-cols-3 gap-8">
        {engagements.map((engagement) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-3xl">{engagement.icon}</span>
              <h3 class="text-lg font-semibold text-slate">{engagement.title}</h3>
            </div>
            <p class="text-slate-light text-sm mb-4">{engagement.description}</p>
            <ul class="space-y-2 mb-6">
              {engagement.bullets.map((bullet) => (
                <li class="flex items-start gap-2 text-sm text-slate-light">
                  <svg class="w-4 h-4 text-brand-blue mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
            <div class="border-t border-gray-100 pt-4 mt-auto">
              <div class="flex justify-between items-center text-sm">
                <div>
                  <span class="text-slate-light">Investment:</span>
                  <span class="font-semibold text-slate ml-1">{engagement.investment}</span>
                </div>
                <div>
                  <span class="text-slate-light">Timeline:</span>
                  <span class="font-semibold text-brand-blue ml-1">{engagement.timeline}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="how-it-works" class="py-16 lg:py-24">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">How It Works</h2>
      <p class="mt-4 text-center text-slate-light">A lightweight process designed for busy teams</p>
      <p class="mt-2 text-center text-slate-light text-sm">Many projects begin with a small diagnostic or prototype so you can see real value before committing to larger systems.</p>
      <div class="mt-12 grid md:grid-cols-5 gap-6">
        {processSteps.map((step, index) => (
          <div class="text-center">
            <div class="w-12 h-12 bg-brand-blue text-white rounded-full flex items-center justify-center mx-auto font-bold text-lg">
              {index + 1}
            </div>
            <h3 class="mt-4 font-semibold text-slate">{step.title}</h3>
            <p class="text-sm text-brand-blue font-medium">{step.duration}</p>
            <p class="mt-2 text-sm text-slate-light">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Selected Projects Section -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-bold text-slate text-center">Selected Projects</h2>
      <p class="mt-4 text-center text-slate-light max-w-2xl mx-auto">
        Recent work across automation, machine learning, and intelligent systems.
      </p>
      <div class="mt-12 grid md:grid-cols-2 gap-8">
        {projects.map((project) => (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
            <div class="bg-brand-blue-pale px-6 py-4">
