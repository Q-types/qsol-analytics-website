---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';

const caseStudies = [
  {
    title: 'AI Lesson Planner for Science Cover Teaching',
    category: 'Workflow Automation & AI',
    problem: 'Teachers and cover staff often lose time preparing lessons at different difficulty levels and adapting content quickly.',
    solution: 'Developed a Python-based lesson planning system that integrates educational best practice, syllabus content, challenge tasks, and knowledge-check questions to generate structured lesson plans efficiently.',
    outcomes: [
      'Reduces lesson preparation time',
      'Improves consistency of lesson structure',
      'Supports differentiated delivery across ability levels'
    ],
    href: '/case-studies/ai-lesson-planner/'
  },
  {
    title: 'Estimating and MIS System for Bespoke Manufacturing',
    category: 'Operational Data Systems',
    problem: 'A bespoke packaging manufacturer relied on manual estimating processes and fragmented management information, making quoting and decision-making slow and inconsistent.',
    solution: 'Designed and scoped a smarter estimating / MIS system to centralise operational variables, automate parts of the quoting process, and support more reliable management insight.',
    outcomes: [
      'Reduces estimating friction',
      'Improves consistency in quoting',
      'Lays the foundation for stronger operational reporting'
    ],
    href: '/case-studies/manufacturing-mis/'
  },
  {
    title: 'Customer Clustering and Recommendation Modelling',
    category: 'Machine Learning & Customer Intelligence',
    problem: 'Businesses often hold customer data but lack clear ways to identify meaningful groups, prioritise opportunities, or understand which customers respond to different products.',
    solution: 'Developed clustering and recommendation approaches to uncover behavioural patterns in customer data and support smarter targeting and prioritisation.',
    outcomes: [
      'Helps businesses understand customer segments',
      'Improves targeting and prioritisation',
      'Supports more informed commercial decision-making'
    ],
    href: '/case-studies/customer-clustering/'
  }
];
---

<BaseLayout
  title="Selected Projects"
  description="Real data science projects across automation, machine learning, and AI — from workflow automation to customer intelligence systems."
>
  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold text-slate">Selected Projects</h1>
        <p class="mt-6 text-xl text-slate-light">
          Recent work across automation, machine learning, and intelligent systems. Each project focused on practical business outcomes.
        </p>
      </div>

      <div class="mt-12 grid lg:grid-cols-3 gap-8">
        {caseStudies.map((study) => (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
            <div class="bg-brand-blue-pale px-6 py-4">
              <span class="text-xs font-medium text-brand-blue uppercase tracking-wide">{study.category}</span>
              <h2 class="mt-1 text-lg font-semibold text-slate">{study.title}</h2>
            </div>
            <div class="p-6 space-y-4">
              <div>
                <h3 class="text-sm font-semibold text-slate mb-1">Problem</h3>
                <p class="text-sm text-slate-light">{study.problem}</p>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-slate mb-1">Solution</h3>
                <p class="text-sm text-slate-light">{study.solution}</p>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-slate mb-2">Outcomes</h3>
                <ul class="space-y-1">
                  {study.outcomes.map((outcome) => (
                    <li class="flex items-start gap-2 text-sm text-slate-light">
                      <svg class="w-4 h-4 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      <span>{outcome}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Ready to see results like these?"
    description="Book a discovery call to discuss your specific challenges and opportunities."
  />
</BaseLayout>
