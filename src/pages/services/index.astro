---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

const services = [
  {
    title: 'Operational Data Systems',
    description: 'Automation and reporting systems that remove manual work. Workflow automation, reporting pipelines, dashboards, and MIS / operational systems that give your team real-time visibility.',
    href: '/services/automation-workflow/',
    icon: '⚙️',
    timeline: '2–4 weeks'
  },
  {
    title: 'Predictive Analytics & Forecasting',
    description: 'Models that forecast demand and detect operational risk. Time-series forecasting, anomaly detection, predictive maintenance, and demand modelling to help you plan ahead.',
    href: '/services/forecasting-anomaly-detection/',
    icon: '📈',
    timeline: '3–6 weeks'
  },
  {
    title: 'Machine Learning Solutions',
    description: 'Models that uncover patterns in complex business data. Clustering & segmentation, recommendation systems, classification models, and ensemble approaches for smarter decisions.',
    href: '/services/customer-segmentation/',
    icon: '🔍',
    timeline: '4–8 weeks'
  },
  {
    title: 'AI & Intelligent Automation',
    description: 'Custom AI tools integrated into operations. GenAI internal tools, AI assistants, agent workflows, and knowledge retrieval systems that bring advanced capabilities within reach.',
    href: '/services/analytics-dashboards/',
    icon: '🤖',
    timeline: '3–6 weeks'
  }
];
---

<BaseLayout
  title="Data Science & AI Services for UK SMEs"
  description="Operational data systems, predictive analytics, machine learning, and AI tools built for operations-heavy UK SMEs. Measurable results in weeks, not months."
>
  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold text-slate">Our Services</h1>
        <p class="mt-6 text-xl text-slate-light">
          From automation and dashboards to machine learning and AI tools—practical data science solutions designed for UK SMEs. Every service delivers measurable outcomes, agreed upfront.
        </p>
      </div>

      <div class="mt-16 grid md:grid-cols-2 gap-8">
        {services.map((service) => (
          <a href={service.href} class="block bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg hover:border-brand-blue-light transition-all group">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-3xl">{service.icon}</span>
              <h2 class="text-xl font-semibold text-slate group-hover:text-brand-blue transition-colors">{service.title}</h2>
            </div>
            <p class="text-slate-light">{service.description}</p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-sm text-brand-blue font-medium">Typical timeline: {service.timeline}</span>
              <span class="text-brand-blue group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="container-narrow">
      <h2 class="text-3xl font-bold text-slate text-center">How We Work</h2>
      <div class="mt-12 space-y-8">
        <div class="flex gap-6">
          <div class="flex-shrink-0 w-12 h-12 bg-brand-blue text-white rounded-full flex items-center justify-center font-bold">1</div>
          <div>
            <h3 class="font-semibold text-slate">Discovery Call (30 minutes)</h3>
            <p class="mt-2 text-slate-light">We discuss your current setup, pain points, and goals. You'll leave with a clear sense of whether we're a fit—no hard sell.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="flex-shrink-0 w-12 h-12 bg-brand-blue text-white rounded-full flex items-center justify-center font-bold">2</div>
          <div>
            <h3 class="font-semibold text-slate">Assessment (1-3 days)</h3>
            <p class="mt-2 text-slate-light">We review your existing data and systems. You receive a written assessment highlighting quick wins and strategic opportunities.</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="flex-shrink-0 w-12 h-12 bg-brand-blue text-white rounded-full flex items-center justify-center font-bold">3</div>
          <div>
            <h3 class="font-semibold text-slate">Build & Deliver (2-4 weeks)</h3>
            <p class="mt-2 text-slate-light">We build a working solution you can test with real data. Full documentation and handover—or ongoing support. You choose.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
