---
interface Props {
  title?: string;
  description?: string;
  primaryCTA?: {
    text: string;
    href: string;
  };
  secondaryCTA?: {
    text: string;
    href: string;
  };
}

const {
  title = "Ready to stop firefighting?",
  description = "Book a free discovery call to discuss how data science and automation can help your business.",
  primaryCTA = { text: "Book a Discovery Call", href: "/contact/" },
  secondaryCTA
} = Astro.props;
---

<section class="bg-brand-blue py-16">
  <div class="container-narrow text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white">
      {title}
    </h2>
    <p class="mt-4 text-lg text-blue-100 max-w-2xl mx-auto">
      {description}
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={primaryCTA.href}
        class="inline-flex items-center justify-center px-8 py-4 bg-white text-brand-blue font-semibold rounded-md hover:bg-gray-100 transition-colors"
      >
        {primaryCTA.text}
      </a>
      {secondaryCTA && (
        <a
          href={secondaryCTA.href}
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-semibold rounded-md hover:bg-white hover:text-brand-blue transition-colors"
        >
          {secondaryCTA.text}
        </a>
      )}
    </div>
  </div>
</section>
