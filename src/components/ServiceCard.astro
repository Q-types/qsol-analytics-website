---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon } = Astro.props;
---

<a
  href={href}
  class="block p-6 bg-white border border-gray-200 rounded-lg hover:shadow-lg hover:border-brand-blue-light transition-all group"
>
  {icon && (
    <div class="w-12 h-12 bg-brand-blue-pale rounded-lg flex items-center justify-center mb-4 group-hover:bg-brand-blue group-hover:text-white transition-colors">
      <span class="text-2xl">{icon}</span>
    </div>
  )}
  <h3 class="text-lg font-semibold text-slate group-hover:text-brand-blue transition-colors">
    {title}
  </h3>
  <p class="mt-2 text-slate-light text-sm">
    {description}
  </p>
  <span class="mt-4 inline-flex items-center text-brand-blue text-sm font-medium">
    Learn more
    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
